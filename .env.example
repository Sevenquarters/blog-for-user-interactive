# Template only.
# Copy this file to `.env.local` for local development.
# Next.js does not load `.env.example` automatically at runtime.

# Required for local login and Supabase client initialization
# Use the project base URL from Supabase, for example:
# https://your-project-id.supabase.co
# Do not use the REST endpoint URL ending with /rest/v1/.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# Recommended for auth email redirects in local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional for the current phase. Keep server-only.
SUPABASE_SECRET_KEY=sb_secret_your_secret_key
